generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Animal {
  id        String   @id
  donor     String
  type      String   @default("Sapi")
  weight    Float    @default(0)
  status    String   @default("Antri")
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Recipient {
  id        String   @id
  name      String
  address   String?
  status    String   @default("Belum")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

/// Tabel khusus portal verifikasi sertifikat Nexovate.
/// Tidak menyentuh tabel lain di database Supabase yang sudah ada.
model NexovateCertificate {
  id                          String   @id @default(cuid())
  certificateNumber           String   @unique @map("certificate_number")
  normalizedCertificateNumber String   @unique @map("normalized_certificate_number")
  participantName             String   @map("participant_name")
  courseName                  String   @map("course_name")
  completionDate              String   @map("completion_date")
  issuer                      String   @default("Nexovate")
  verified                    Boolean  @default(true)
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")
  qrCodeUrl                   String?  @map("qr_code_url")

  @@map("nexovate_certificates")
}
